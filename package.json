{
  "name": "picgo-plugin-optimization",
  "version": "1.1.2",
  "description": "基于 sharp 的 PicGo 图片格式转换和压缩插件",
  "author": "CaoMeiYouRen",
  "private": false,
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "release": "semantic-release",
    "lint": "cross-env NODE_ENV=production eslint . --fix",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsdown",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:tsup": "cross-env NODE_ENV=development tsdown --watch",
    "start": "node ./dist/index",
    "start:tsx": "cross-env NODE_ENV=production tsx src/index.ts",
    "commit": "cz",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^21.0.2",
    "@types/debug": "^4.1.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "4.1.5",
    "commitizen": "^4.3.1",
    "commitlint": "^21.0.2",
    "commitlint-config-cmyr": "^1.0.1",
    "cross-env": "^10.0.0",
    "cz-conventional-changelog": "^3.3.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.4.3",
    "eslint": "^9.39.2",
    "eslint-config-cmyr": "^2.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "picgo": "^2.0.3",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "semantic-release-cmyr-config": "^1.0.2",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  },
  "config": {},
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "pnpm run lint"
    ]
  },
  "keywords": [
    "picgo-gui-plugin",
    "picgo-plugin",
    "picgo",
    "sharp",
    "optimization",
    "image",
    "compress",
    "typescript"
  ],
  "homepage": "https://github.com/CaoMeiYouRen/picgo-plugin-optimization#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/picgo-plugin-optimization.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/picgo-plugin-optimization/issues"
  },
  "dependencies": {
    "file-type": "^22.0.1",
    "fs-extra": "^11.3.5",
    "image-size": "^2.0.2",
    "sharp": "^0.34.4",
    "tslib": "^2.8.1"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  }
}
